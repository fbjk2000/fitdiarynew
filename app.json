{
  "expo": {
    "name": "FitDiary",
    "slug": "fitdiary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0a1f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fitdiary.fintery",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0f0a1f",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "fitdiary.fintery"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d72b4a36-38da-4164-81d3-25cbcd0c1ce5"
      }
    },
    "owner": "fbjk2000ai",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "FitDiary uses your photo library so you can add meal photos and profile pictures.",
          "cameraPermission": "FitDiary uses your camera so you can snap meal photos and estimate nutrition."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ff7a5c"
        }
      ]
    ]
  }
}
