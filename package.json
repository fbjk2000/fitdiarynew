{
  "name": "fitdiary",
  "version": "1.0.0",
  "description": "Fitness tracker built with Expo and React Native",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:env": "powershell -ExecutionPolicy Bypass -File scripts/start-expo-env.ps1",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "vision:server": "node server/vision-proxy.mjs",
    "vision:server:env": "powershell -ExecutionPolicy Bypass -File scripts/start-vision-server.ps1"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^54.0.0",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "playwright": "^1.53.0",
    "typescript": "~5.9.2"
  },
  "keywords": [
    "fitness",
    "workout",
    "nutrition",
    "health",
    "tracker",
    "react-native",
    "expo"
  ],
  "author": "Your Name",
  "license": "MIT"
}
